#
# bsptile via sxhkd
#
# sxhkd owns key/mouse grabs. bsptile exposes actions through bsptilectl.
#
# Suggested use:
#   cp assets/sxhkdrc.example ~/.config/sxhkd/sxhkdrc.bsptile
#   sxhkd -c ~/.config/sxhkd/sxhkdrc.bsptile &
#
# Reload sxhkd after edits:
#   super + Escape
#

#
# desktop/session hotkeys
#

# terminal
super + Return
    xfce4-terminal

# launcher
super + d
    rofi -show drun

# whisker menu
super + @space
    xfce4-popup-whiskermenu

# reload sxhkd
super + Escape
    pkill -USR1 -x sxhkd

#
# media
#

XF86AudioMute
    pactl set-sink-mute @DEFAULT_SINK@ toggle

XF86AudioLowerVolume
    pactl set-sink-volume @DEFAULT_SINK@ -5%

XF86AudioRaiseVolume
    pactl set-sink-volume @DEFAULT_SINK@ +5%

XF86AudioMicMute
    pactl set-source-mute @DEFAULT_SOURCE@ toggle

XF86MonBrightnessDown
    brightnessctl set 5%-

XF86MonBrightnessUp
    brightnessctl set 5%+

Print
    sh -c 'maim -s | xclip -selection clipboard -t image/png'

#
# bsptile: tiling state
#

super + o
    bsptilectl action toggle

super + Home
    bsptilectl action enable

super + End
    bsptilectl action disable

ctrl + shift + d
    bsptilectl action decoration

ctrl + shift + r
    bsptilectl action restore

ctrl + shift + BackSpace
    bsptilectl action reset

super + q
    bsptilectl action close

super + shift + space
    bsptilectl action window_floating

ctrl + shift + b
    bsptilectl action balance

ctrl + shift + c
    bsptilectl reload

#
# bsptile: layouts
#

super + r
    bsptilectl action tree_rotate

super + e
    bsptilectl action layout_bsp

super + m
    bsptilectl action layout_maximized

super + f
    bsptilectl action layout_fullscreen

#
# bsptile: focus
#

super + {h,j,k,l}
    bsptilectl action window_{left,down,up,right}

super + {Left,Down,Up,Right}
    bsptilectl action window_{left,down,up,right}

super + Tab
    bsptilectl action window_next

super + shift + Tab
    bsptilectl action window_previous

#
# bsptile: window movement
#

super + shift + {h,j,k,l}
    bsptilectl action move_window_{left,down,up,right}

super + shift + {Left,Down,Up,Right}
    bsptilectl action move_window_{left,down,up,right}

super + ctrl + j
    bsptilectl action position_next

super + ctrl + k
    bsptilectl action position_previous

# Send the active window to a numbered desktop through bsptile so both BSP
# trees stay consistent.
super + shift + {1-9}
    bsptilectl action window_to_desktop_{1-9}

super + shift + bracketleft
    bsptilectl action window_to_desktop_previous

super + shift + bracketright
    bsptilectl action window_to_desktop_next

# Switch the visible desktop without moving the active window.
super + {1-9}
    bsptilectl action desktop_{1-9}

super + bracketleft
    bsptilectl action desktop_previous

super + bracketright
    bsptilectl action desktop_next

# Uncomment if you want monitor-send shortcuts.
# super + alt + l
#     bsptilectl action screen_next
# super + alt + h
#     bsptilectl action screen_previous

#
# bsptile: proportion and resize
#

super + plus
    bsptilectl action proportion_increase

super + minus
    bsptilectl action proportion_decrease

super + alt + {h,j,k,l}
    bsptilectl action resize_{left,down,up,right}

super + alt + {Left,Down,Up,Right}
    bsptilectl action resize_{left,down,up,right}

# Sticky resize chord. Press super+shift+r, then a direction.
super + shift + r : {h,j,k,l}
    bsptilectl action resize_{left,down,up,right}

super + shift + r : {Left,Down,Up,Right}
    bsptilectl action resize_{left,down,up,right}

#
# bsptile: mouse buttons
#
# sxhkd can bind high mouse buttons too. Use `xev` to identify button numbers.
#
# button12
#     bsptilectl action layout_maximized

#
# bsptile: broadcast modifiers
#

super + alt + o
    bsptilectl action toggle --mod screens

super + ctrl + alt + o
    bsptilectl action toggle --mod workspaces

#
# bsptile: lifecycle
#

super + ctrl + shift + r
    bsptilectl wm restart

super + ctrl + shift + q
    bsptilectl wm exit
